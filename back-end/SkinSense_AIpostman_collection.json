{
  "info": {
    "name": "SkinSense AI — API",
    "description": "API collection untuk SkinSense AI Backend\nCapstone Pijak × IBM SkillsBuild — PJK-GM066\n\nSetup:\n1. Jalankan `python run.py` di folder back-end/\n2. Set variable `base_url` ke http://localhost:5000\n3. Set variable `weatherapi_key` di .env\n4. Jalankan Register/Login dulu → token otomatis tersimpan",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "guest_user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "guest_session_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "questionnaire_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Homepage (HTML)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Halaman utama — menampilkan system status dan API documentation"
          }
        },
        {
          "name": "Status (JSON)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/status",
              "host": ["{{base_url}}"],
              "path": ["api", "status"]
            },
            "description": "JSON health check — model status, DB, WeatherAPI key"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.collectionVariables.set('user_id', json.user_id);",
                  "    pm.test('Register berhasil — token & user_id tersimpan', function () {",
                  "        pm.expect(json.token).to.be.a('string');",
                  "        pm.expect(json.user_id).to.be.a('string');",
                  "        pm.expect(json.email).to.be.a('string');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@skinsense.ai\",\n  \"password\": \"password123\",\n  \"name\": \"Test User\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register user baru. Token otomatis tersimpan ke collection variable."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.collectionVariables.set('user_id', json.user_id);",
                  "    pm.test('Login berhasil — token & user_id tersimpan', function () {",
                  "        pm.expect(json.token).to.be.a('string');",
                  "        pm.expect(json.user_id).to.be.a('string');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@skinsense.ai\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login dengan email & password. Token otomatis tersimpan ke collection variable."
          }
        },
        {
          "name": "Guest Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('guest_user_id', json.user_id);",
                  "    pm.collectionVariables.set('guest_session_token', json.session_token);",
                  "    pm.test('Guest session dibuat — user_id & session_token tersimpan', function () {",
                  "        pm.expect(json.user_id).to.be.a('string');",
                  "        pm.expect(json.session_token).to.be.a('string');",
                  "        pm.expect(json.expires_at).to.be.a('string');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/guest",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "guest"]
            },
            "description": "Buat guest session tanpa register. session_token otomatis tersimpan."
          }
        },
        {
          "name": "Me (Current User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Get current user berhasil', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.user_id).to.be.a('string');",
                  "    pm.expect(json).to.have.property('email');",
                  "    pm.expect(json).to.have.property('is_guest');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Get info user yang sedang login. Butuh token dari Register/Login."
          }
        }
      ]
    },
    {
      "name": "Recommend",
      "item": [
        {
          "name": "Recommend — Moisturizer (Registered User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('questionnaire_id', json.questionnaire_id);",
                  "    pm.test('Rekomendasi berhasil', function () {",
                  "        pm.expect(json.questionnaire_id).to.be.a('string');",
                  "        pm.expect(json.weather).to.have.property('temperature');",
                  "        pm.expect(json.weather).to.have.property('humidity');",
                  "        pm.expect(json.weather).to.have.property('uv_index');",
                  "        pm.expect(json.weather).to.have.property('pm25');",
                  "        pm.expect(json.recommendations).to.be.an('array');",
                  "        pm.expect(json.recommendations.length).to.be.greaterThan(0);",
                  "        pm.expect(json.recommendations[0]).to.have.property('rank');",
                  "        pm.expect(json.recommendations[0]).to.have.property('product_name');",
                  "        pm.expect(json.recommendations[0]).to.have.property('score');",
                  "        pm.expect(json.recommendations[0]).to.have.property('why_recommended');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"questionnaire\": {\n    \"product_category\": \"moisturizer\",\n    \"skin_type\": \"oily\",\n    \"skin_concerns\": [\"acne\", \"dullness\"],\n    \"activity_type\": null,\n    \"avoided_ingredients\": [\"retinol\"]\n  },\n  \"location\": {\n    \"lat\": -6.2088,\n    \"lon\": 106.8456,\n    \"method\": \"gps\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/recommend",
              "host": ["{{base_url}}"],
              "path": ["api", "recommend"]
            },
            "description": "Rekomendasi moisturizer untuk registered user.\nLokasi: Jakarta. Kulit: oily. Concern: acne + dullness."
          }
        },
