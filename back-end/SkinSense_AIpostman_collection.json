                  "        pm.expect(json.recommendations).to.be.an('array');",
                  "        json.recommendations.forEach(function(rec) {",
                  "            pm.expect(rec.category).to.equal('sunscreen');",
                  "        });",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
