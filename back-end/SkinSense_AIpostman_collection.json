          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"questionnaire\": {\n    \"product_category\": \"sunscreen\",\n    \"skin_type\": \"combination\",\n    \"skin_concerns\": [\"aging\", \"dark spots\"],\n    \"activity_type\": \"outdoor\",\n    \"avoided_ingredients\": []\n  },\n  \"location\": {\n    \"lat\": -2.9909,\n    \"lon\": 104.7566,\n    \"method\": \"gps\"\n  }\n}"
            },
            "url": {
