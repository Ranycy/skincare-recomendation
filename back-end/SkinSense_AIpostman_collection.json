    {
      "name": "History",
      "item": [
        {
          "name": "Get History (Registered User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('History berhasil diambil', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.history).to.be.an('array');",
                  "    if (json.history.length > 0) {",
                  "        var entry = json.history[0];",
                  "        pm.expect(entry).to.have.property('questionnaire_id');",
                  "        pm.expect(entry).to.have.property('weather');",
                  "        pm.expect(entry).to.have.property('recommendations');",
                  "        pm.expect(entry).to.have.property('created_at');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/history",
              "host": ["{{base_url}}"],
              "path": ["api", "history"]
            },
            "description": "Ambil semua riwayat rekomendasi untuk user yang login.\nJalankan beberapa Recommend request dulu agar ada data."
          }
        },
