# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/skinsense

# WeatherAPI - daftar di https://www.weatherapi.com/
WEATHERAPI_KEY=your-weatherapi-key

# Path ke folder machine-learning (default: ../machine-learning relatif dari back-end/)
ML_MODEL_PATH=../machine-learning

# JWT & Guest session (jam)
JWT_EXPIRATION_HOURS=24
GUEST_SESSION_HOURS=24
